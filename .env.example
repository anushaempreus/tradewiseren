# --- Contact form → Microsoft 365 mailbox (via Graph API) ---
# App registration in the client's M365 tenant with Mail.Send application
# permission (admin-consented). Empreus manages the tenant.
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=
# Mailbox the enquiry is sent FROM (must exist in the tenant)
M365_SENDER=website@tradewiserenovations.com
# Where enquiries are delivered (defaults to info@tradewiserenovations.com)
CONTACT_RECIPIENT=info@tradewiserenovations.com

# --- Newsletter form → MailerLite (account 1924740) ---
# MailerLite dashboard → Integrations → API
MAILERLITE_API_KEY=
# Optional: group to file website signups under
MAILERLITE_GROUP_ID=
